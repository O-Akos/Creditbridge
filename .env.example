# --- BACKEND SETTINGS / BACKEND BEÁLLÍTÁSOK ---
PORT=5000
NODE_ENV=development

# --- DATABASE (PostgreSQL) / ADATBÁZIS (PostgreSQL) ---
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=your_database_name
DB_PORT=5432
# Use 'db' for Docker, 'localhost' for native execution
# Docker használata esetén a host: db, natív futtatásnál: localhost
DB_HOST=localhost

# --- AUTHENTICATION / HITELESÍTÉS ---
# Enter a long, random secret key here
JWT_SECRET=your_secret_key_here

# --- FRONTEND CONNECTION / FRONTEND KAPCSOLAT ---
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000

# --- E-MAIL SETTINGS ---
# Use 'mailhog' for Docker, 'localhost' for native execution
EMAIL_HOST=localhost
EMAIL_PORT=1025

# --- EXTERNAL API KEYS / KÜLSŐ API KULCSOK ---
TTR_API_KEY=your_ttr_api_key_here